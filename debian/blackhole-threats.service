[Unit]
Description=Blackhole threats BGP daemon
Documentation=man:blackhole-threats(8)
Documentation=https://github.com/soakes/blackhole-threats
After=network.target

[Service]
Type=simple
EnvironmentFile=-/etc/default/blackhole-threats
ExecStart=/usr/sbin/blackhole-threats -conf $CONF $EXTRA_OPTS
ExecReload=/bin/kill -USR1 $MAINPID
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=full
Restart=on-failure

[Install]
WantedBy=multi-user.target
